{
  "name": "@restforgejs/mcp-server",
  "version": "1.2.6",
  "description": "RESTForge MCP Server — Model Context Protocol server that exposes RESTForge Platform commands to AI agents (Claude Desktop, Cursor, Claude CLI, and other MCP clients). Orchestrates project setup, code generation, and runtime launch via natural language. A thin orchestrator for the RESTForge Platform CLI, not a generic MCP framework or API testing tool.",
  "type": "module",
  "bin": {
    "restforge-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "restforge",
    "ai-agent",
    "claude",
    "cursor",
    "rest-api",
    "code-generator"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "license": "MIT",
  "author": {
    "name": "RESTForge Development Team",
    "url": "https://restforge.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/restforge/mcp-server.git"
  },
  "homepage": "https://github.com/restforge/mcp-server#readme",
  "bugs": {
    "url": "https://github.com/restforge/mcp-server/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "execa": "^9.6.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
